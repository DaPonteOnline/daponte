# Da Ponte Online — Apache config for the static build.
# This site is 100% static (HTML/CSS/JS); no server runtime is required.

# Serve index.html for directory URLs. Astro uses build.format = "directory",
# so every route is <path>/index.html.
DirectoryIndex index.html

# This docroot is a git clone (deployed via `git pull`). Block web access to the
# repo's own metadata — without this, the full history would be downloadable at
# /.git/. Covers .git/, .gitignore, .gitattributes. .htaccess is denied by
# Apache's default config; DEPLOY.md is harmless docs but blocked here too.
RedirectMatch 404 /\.git
<FilesMatch "(^\.ht|^DEPLOY\.md$)">
  Require all denied
</FilesMatch>

# Send the bare root straight to the Italian home as a real HTTP 302, so
# visitors never see the static "Redirecting…" interstitial (dist/index.html).
# "^/$" matches the exact root ONLY — it cannot loop on /it/ or catch any
# deeper path. The interstitial page stays in place as a no-.htaccess fallback.
RedirectMatch 302 ^/$ /it/

# Pagefind (client-side full-text search) ships a WebAssembly module. If .wasm
# is served as text/plain, search silently fails. Force the correct MIME type.
AddType application/wasm .wasm

# Custom 404 page (Astro builds dist/404.html).
# This build is mounted at the DOMAIN ROOT (BASE_PATH=/):
ErrorDocument 404 /404.html
#
# If you instead mount the site in a SUB-FOLDER on Dharc, you MUST rebuild the
# whole artifact with the matching base (see DEPLOY.md), then comment the line
# above and use:
# ErrorDocument 404 /YOUR_DHARC_PATH_HERE/404.html
